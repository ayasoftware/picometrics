# ── Infrastructure ────────────────────────────────────────────────────
NODE_ENV=development

POSTGRES_USER=marketing_ai
POSTGRES_PASSWORD=changeme_postgres
# Constructed automatically by docker-compose:
# DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/marketing_ai

REDIS_PASSWORD=changeme_redis

# ── LLM ───────────────────────────────────────────────────────────────
OLLAMA_MODEL=qwen3:14b
# OLLAMA_MODEL=qwen3:7b   # smaller option for dev

# ── Backend Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_64_hex_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# AES-256-GCM key for OAuth token encryption (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key_for_token_encryption

# Shared secret between backend and MCP servers (prevents direct MCP access)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=CHANGE_ME_internal_secret

# Static API key that Open WebUI uses to authenticate against the backend proxy
# Generate with: openssl rand -hex 32
OPEN_WEBUI_API_KEY=CHANGE_ME_open_webui_key

# Open WebUI internal secret
WEBUI_SECRET_KEY=CHANGE_ME_webui_secret

# ── OAuth — Base URL ──────────────────────────────────────────────────
# The publicly accessible URL of your backend (used for OAuth redirect URIs)
OAUTH_REDIRECT_BASE_URL=http://localhost:4000

# ── Google OAuth (Ads + Analytics + GTM — single app) ────────────────
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to register: ${OAUTH_REDIRECT_BASE_URL}/api/oauth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Google Ads developer token (from Google Ads API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# ── LinkedIn OAuth ────────────────────────────────────────────────────
# App: https://www.linkedin.com/developers/apps
# Redirect URI: ${OAUTH_REDIRECT_BASE_URL}/api/oauth/callback/linkedin
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# ── Facebook / Meta OAuth ─────────────────────────────────────────────
# App: https://developers.facebook.com/apps
# Redirect URI: ${OAUTH_REDIRECT_BASE_URL}/api/oauth/callback/facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── OpenClaw provisioning ─────────────────────────────────────────────
# Pin to a specific release to control upgrades; defaults to :latest.
# After changing this tag, call POST /admin/provision/upgrade-all to roll it out.
PROVISIONING_OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# PROVISIONING_OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:v2026.4.24

# Internal Docker network shared by the backend, Caddy, and OpenClaw containers.
# Matches the `networks.openclaw_internal.name` in docker-compose.yml.
OPENCLAW_DOCKER_NETWORK=marketing-ai-platform_openclaw_internal
